body {
  margin: 0;
  font-family: Arial;
  background: #0a0f1c;
  color: white;
  text-align: center;
}

header {
  padding: 40px;
  background: linear-gradient(90deg, #0a0f1c, #0f2a5a);
}

.hero {
  padding: 60px;
}

.services {
  display: flex;
  justify-content: center;
  gap: 20px;
  padding: 40px;
}

.services div {
  padding: 20px;
  background: #111c3a;
  border-radius: 10px;
}